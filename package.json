{
  "name": "grok-cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "grok": "dist/cli.js"
  },
  "scripts": {
    "build": "tsup src/cli.ts --format esm --clean --out-dir dist",
    "dev": "tsx src/cli.ts",
    "grok": "tsx src/cli.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "latest",
    "tsup": "latest",
    "tsx": "latest",
    "typescript": "latest",
    "vitest": "latest"
  }
}
